<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SunMoonResort" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (resort gold) -->
        <item name="colorPrimary">@color/resort_gold</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/resort_gold_dark</item>
        <!-- Tertiary color -->
        <item name="colorTertiary">@color/background_off_white</item>
        <!-- Error color -->
        <item name="colorError">@color/red_error</item>
        <!-- Surface colors -->
        <item name="colorSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/gray_light</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_dark</item>
        <item name="android:textColorSecondary">@color/text_brown</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Theme.SunMoonResort" parent="Base.Theme.SunMoonResort" />
</resources>