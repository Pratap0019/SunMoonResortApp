<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_off_white"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="32dp"
    android:paddingBottom="32dp"
    android:layout_marginTop="32dp">

    <!-- Top Border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/resort_gold"
        android:layout_marginBottom="24dp" />

    <!-- Contact Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_us"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/resort_gold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/phone_label"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/phone_number"
            android:textSize="11sp"
            android:textColor="@color/text_brown"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/email_label"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/email_contact"
            android:textSize="11sp"
            android:textColor="@color/text_brown" />
    </LinearLayout>

    <!-- Services Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/our_services"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/resort_gold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ @string/luxury_rooms"
            android:textSize="11sp"
            android:textColor="@color/text_brown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ @string/sea_view"
            android:textSize="11sp"
            android:textColor="@color/text_brown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ @string/wifi_amenities"
            android:textSize="11sp"
            android:textColor="@color/text_brown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ @string/room_service"
            android:textSize="11sp"
            android:textColor="@color/text_brown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ @string/pet_friendly"
            android:textSize="11sp"
            android:textColor="@color/text_brown" />
    </LinearLayout>

    <!-- Footer Bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="16dp"
        android:borderTopColor="@color/resort_gold"
        android:borderTop="1dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_copyright"
            android:textSize="11sp"
            android:textColor="@color/text_brown"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_tagline"
            android:textSize="10sp"
            android:textColor="@color/text_brown"
            android:gravity="center" />
    </LinearLayout>
</LinearLayout>

