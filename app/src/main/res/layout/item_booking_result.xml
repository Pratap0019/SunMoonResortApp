<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp">

            <!-- Top Row: Booking ID, Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:baselineAligned="false"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/booking_id_label"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/booking_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:textSize="11sp"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/customer_name"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/guest_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_dark"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <com.google.android.material.chip.Chip
                    android:id="@+id/booking_status"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:textSize="11sp"
                    app:chipMinHeight="30dp"
                    app:ensureMinTouchTargetSize="false" />
            </LinearLayout>

            <!-- Room and Dates -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/room_label"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/room_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/room_result_separator"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:includeFontPadding="false" />

                        <TextView
                            android:id="@+id/room_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/resort_gold"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:includeFontPadding="false" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/check_in_label"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/check_in_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_dark"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/check_out_label"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/check_out_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_dark"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_light"
                android:layout_marginBottom="6dp" />

            <!-- Total Amount and Action -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_amount"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/total_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/resort_gold"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cancel_booking_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_gravity="center_vertical"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="@string/cancel"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:visibility="gone"
                    app:backgroundTint="@color/red_error"
                    app:cornerRadius="8dp" />

                <TextView
                    android:id="@+id/action_placeholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/na"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>

