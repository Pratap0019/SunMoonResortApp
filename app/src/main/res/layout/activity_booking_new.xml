<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_booking_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header (reuse from home) -->
        <FrameLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/header_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:id="@+id/logo_header"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/sunmoon_logo"
                    android:contentDescription="@string/logo_description"
                    android:scaleType="centerInside" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:src="@drawable/header_decoration"
                    android:contentDescription="@string/decoration_header"
                    android:scaleType="centerCrop" />

                <Button
                    android:id="@+id/admin_btn"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="@string/admin"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="@color/resort_gold"
                    android:background="@color/white"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </FrameLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Page Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/book_your_stay"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/resort_gold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp" />

            <!-- Error Alert -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/error_alert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/red_light"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        android:contentDescription="@string/error"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/red_error" />

                    <TextView
                        android:id="@+id/error_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/red_error"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Booking Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/calculate_price_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Check-in & Check-out Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Check-in Date -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/check_in_date"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"
                                android:layout_marginBottom="6dp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxCornerRadiusBottomEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp"
                                app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusTopStart="8dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/check_in_date"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:hint="@string/select_date"
                                    android:inputType="date"
                                    android:textSize="14sp"
                                    android:focusable="false"
                                    android:clickable="true" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:id="@+id/check_in_error"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/check_in_error"
                                android:textSize="11sp"
                                android:textColor="@color/red_error"
                                android:layout_marginTop="4dp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <!-- Check-out Date -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/check_out_date"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"
                                android:layout_marginBottom="6dp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxCornerRadiusBottomEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp"
                                app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusTopStart="8dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/check_out_date"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:hint="@string/select_date"
                                    android:inputType="date"
                                    android:textSize="14sp"
                                    android:focusable="false"
                                    android:clickable="true" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:id="@+id/check_out_error"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/check_out_error"
                                android:textSize="11sp"
                                android:textColor="@color/red_error"
                                android:layout_marginTop="4dp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Days Stayed & Check Availability -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/days_stayed"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"
                                android:layout_marginBottom="6dp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxCornerRadiusBottomEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp"
                                app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusTopStart="8dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/days_stayed"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:inputType="number"
                                    android:textSize="14sp"
                                    android:enabled="false" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <Button
                            android:id="@+id/check_availability_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="@string/check_availability"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@color/resort_gold"
                            android:textColor="@color/white"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp" />
                    </LinearLayout>

                    <!-- Room Type Selection -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/room_type"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="6dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusTopStart="8dp">

                            <AutoCompleteTextView
                                android:id="@+id/room_type_spinner"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:hint="@string/select_room_type_first"
                                android:inputType="none"
                                android:textSize="14sp"
                                android:enabled="false" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/select_dates_first"
                            android:textSize="11sp"
                            android:textColor="@color/gray_light"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Extras Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/extras"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:id="@+id/extras_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <!-- SPA Sessions Picker (conditionally shown) -->
                        <LinearLayout
                            android:id="@+id/spa_sessions_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="12dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/spa_sessions"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"
                                android:layout_marginBottom="6dp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                app:boxCornerRadiusBottomEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp"
                                app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusTopStart="8dp">

                                <AutoCompleteTextView
                                    android:id="@+id/spa_sessions_spinner"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:inputType="none"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Pet Weight -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pet_weight_kg"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="6dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusTopStart="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/pet_weight"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:hint="@string/optional"
                                android:inputType="numberDecimal"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Calculate Price Button -->
                    <Button
                        android:id="@+id/calculate_price_btn"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/calculate_price"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@color/resort_gold"
                        android:textColor="@color/white"
                        android:enabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Price Breakdown Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/price_breakdown_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:visibility="gone"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_breakdown"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="16dp" />

                    <!-- Assigned Room Info -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/cream_bg"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/assigned_room"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/resort_gold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/room_labeled"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_dark" />

                                <TextView
                                    android:id="@+id/assigned_room_number"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_dark"
                                    android:layout_marginStart="4dp"
                                    android:layout_marginEnd="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="|"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_dark"
                                    android:layout_marginEnd="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/type_labeled"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_dark" />

                                <TextView
                                    android:id="@+id/assigned_room_type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/resort_gold"
                                    android:layout_marginStart="4dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Breakdown Items RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/breakdown_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:layout_marginBottom="16dp"
                        tools:listitem="@layout/item_breakdown_line" />

                    <!-- Guest Confirmation Form -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:paddingTop="16dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/gray_light"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/guest_details"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="12dp" />

                        <!-- Full Name -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusTopStart="8dp"
                            android:layout_marginBottom="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/guest_name"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:hint="@string/guest_full_name"
                                android:inputType="text"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/name_error"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/name_error"
                            android:textSize="11sp"
                            android:textColor="@color/red_error"
                            android:layout_marginBottom="8dp"
                            android:visibility="gone" />

                        <!-- Contact Number -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxCornerRadiusBottomEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp"
                                app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusTopStart="8dp"
                                app:prefixText="+91">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/contact_number"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:hint="@string/ten_digit_mobile"
                                    android:inputType="phone"
                                    android:maxLength="10"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:id="@+id/mobile_error"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mobile_error"
                                android:textSize="11sp"
                                android:textColor="@color/red_error"
                                android:layout_marginTop="4dp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <!-- Confirm Booking Button -->
                        <Button
                            android:id="@+id/confirm_booking_btn"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="@string/confirm_booking"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="@color/resort_gold"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Success Message Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/success_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/green_light"
                android:visibility="gone"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/booking_confirmed"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/green_success"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/success_message"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/green_success"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Footer -->
        <include layout="@layout/footer_section" />
    </LinearLayout>
</ScrollView>

