<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:background="@color/gray_booking_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header (reuse from home) -->
        <FrameLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/header_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="0dp"
                android:paddingEnd="0dp">

                <ImageView
                    android:id="@+id/logo_header"
                    android:layout_width="170dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/logo_description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sunmoon_logo" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/decoration_header"
                    android:scaleType="centerCrop"
                    android:src="@drawable/header_decoration" />

                <ImageButton
                    android:id="@+id/back_btn"
                    android:layout_width="50dp"
                    android:layout_height="40dp"
                    android:background="@color/white"
                    android:contentDescription="@string/back"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_back"
                    app:tint="@color/resort_gold_dark" />
            </LinearLayout>
        </FrameLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Page Title -->
            <TextView
                style="@style/TextSunMoonResortHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:text="@string/book_your_stay"
                android:textColor="@color/resort_gold"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Error Alert -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/error_alert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/red_light"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@string/error"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="@color/red_error" />

                    <TextView
                        android:id="@+id/error_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/red_error"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Booking Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/calculate_price_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Check-in & Check-out Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal">

                        <!-- Check-in Date -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="@string/check_in_date"
                                android:textColor="@color/text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxCornerRadiusBottomEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp"
                                app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusTopStart="8dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/check_in_date"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:clickable="true"
                                    android:focusable="false"
                                    android:hint="@string/select_date"
                                    android:inputType="date"
                                    android:minHeight="48dp"
                                    android:textColor="@color/text_dark"
                                    android:textColorHint="@color/text_light"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:id="@+id/check_in_error"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/check_in_error"
                                android:textColor="@color/red_error"
                                android:textSize="11sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <!-- Check-out Date -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="@string/check_out_date"
                                android:textColor="@color/text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxCornerRadiusBottomEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp"
                                app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusTopStart="8dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/check_out_date"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:clickable="true"
                                    android:focusable="false"
                                    android:hint="@string/select_date"
                                    android:inputType="date"
                                    android:minHeight="48dp"
                                    android:textColor="@color/text_dark"
                                    android:textColorHint="@color/text_light"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:id="@+id/check_out_error"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/check_out_error"
                                android:textColor="@color/red_error"
                                android:textSize="11sp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Days Stayed & Check Availability -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:baselineAligned="false"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="@string/days_stayed"
                                android:textColor="@color/text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxCornerRadiusBottomEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp"
                                app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusTopStart="8dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/days_stayed"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:enabled="false"
                                    android:inputType="number"
                                    android:minHeight="48dp"
                                    android:textColor="@color/text_dark"
                                    android:textColorHint="@color/text_light"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <Button
                            android:id="@+id/check_availability_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_gravity="bottom"
                            android:background="@drawable/bg_primary_action_button"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="@string/check_availability"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Room Type Selection -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="@string/room_type"
                            android:textColor="@color/text_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusTopStart="8dp">

                            <AutoCompleteTextView
                                android:id="@+id/room_type_spinner"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:enabled="false"
                                android:hint="@string/select_room_type_first"
                                android:inputType="none"
                                android:minHeight="48dp"
                                android:textColor="@color/text_dark"
                                android:textColorHint="@color/text_light"
                                android:textSize="13sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/select_dates_first"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Extras Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/extras"
                            android:textColor="@color/text_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/extra_mattress_radio"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_marginBottom="2dp"
                                android:text="@string/extra_mattress_label"
                                android:textColor="@color/text_dark"
                                android:textSize="12sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <RadioButton
                                    android:id="@+id/extra_spa_radio"
                                    android:layout_width="wrap_content"
                                    android:layout_height="36dp"
                                    android:layout_weight="1"
                                    android:text="@string/extra_spa_label"
                                    android:textColor="@color/text_dark"
                                    android:textSize="12sp" />

                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/spa_sessions_container"
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                    android:layout_width="136dp"
                                    android:layout_height="wrap_content"
                                    android:alpha="0.85"
                                    android:enabled="false"
                                    app:boxCornerRadiusBottomEnd="8dp"
                                    app:boxCornerRadiusBottomStart="8dp"
                                    app:boxCornerRadiusTopEnd="8dp"
                                    app:boxCornerRadiusTopStart="8dp">

                                    <AutoCompleteTextView
                                        android:id="@+id/spa_sessions_spinner"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:enabled="false"
                                        android:hint="@string/spa_sessions"
                                        android:inputType="none"
                                        android:minHeight="44dp"
                                        android:textColor="@color/text_dark"
                                        android:textColorHint="@color/text_light"
                                        android:textSize="11sp" />
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>

                            <RadioButton
                                android:id="@+id/extra_gym_radio"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_marginBottom="2dp"
                                android:text="@string/extra_gym_label"
                                android:textColor="@color/text_dark"
                                android:textSize="12sp" />

                            <RadioButton
                                android:id="@+id/extra_pool_radio"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="@string/extra_pool_label"
                                android:textColor="@color/text_dark"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Pet Weight -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="@string/pet_weight_kg"
                            android:textColor="@color/text_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusTopStart="8dp">

                            <AutoCompleteTextView
                                android:id="@+id/pet_weight_spinner"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/optional"
                                android:inputType="none"
                                android:minHeight="48dp"
                                android:textColor="@color/text_dark"
                                android:textColorHint="@color/text_light"
                                android:textSize="13sp" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Calculate Price Button -->
                    <Button
                        android:id="@+id/calculate_price_btn"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_primary_action_button"
                        android:enabled="false"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="@string/calculate_price"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Price Breakdown Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/price_breakdown_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextSunMoonResortHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/price_breakdown"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Assigned Room Info -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/cream_bg"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                style="@style/TextSunMoonResortHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/assigned_room"
                                android:textColor="@color/resort_gold"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/room_labeled"
                                    android:textColor="@color/text_dark"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/assigned_room_number"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:layout_marginEnd="8dp"
                                    android:textColor="@color/text_dark"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:text="|"
                                    android:textColor="@color/text_dark"
                                    android:textSize="11sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/type_labeled"
                                    android:textColor="@color/text_dark"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/assigned_room_type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:textColor="@color/resort_gold"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Breakdown Items RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/breakdown_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_breakdown_line" />

                    <!-- Guest Confirmation Form -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:paddingTop="12dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="12dp"
                            android:background="@color/gray_light" />

                        <TextView
                            style="@style/TextSunMoonResortHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="@string/guest_details"
                            android:textColor="@color/text_dark"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <!-- Full Name -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusTopStart="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/guest_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/guest_full_name"
                                android:inputType="text"
                                android:minHeight="48dp"
                                android:textColor="@color/text_dark"
                                android:textColorHint="@color/text_light"
                                android:textSize="13sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/name_error"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="@string/name_error"
                            android:textColor="@color/red_error"
                            android:textSize="11sp"
                            android:visibility="gone" />

                        <!-- Contact Number -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:orientation="vertical">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxCornerRadiusBottomEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp"
                                app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusTopStart="8dp"
                                app:prefixText="+91"
                                app:prefixTextColor="@color/text_dark">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/contact_number"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="@string/ten_digit_mobile"
                                    android:inputType="phone"
                                    android:maxLength="10"
                                    android:minHeight="48dp"
                                    android:textColor="@color/text_dark"
                                    android:textColorHint="@color/text_light"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:id="@+id/mobile_error"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/mobile_error"
                                android:textColor="@color/red_error"
                                android:textSize="11sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <!-- Confirm Booking Button -->
                        <Button
                            android:id="@+id/confirm_booking_btn"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_primary_action_button"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="@string/confirm_booking"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Success Message Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/success_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/green_light"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:includeFontPadding="false"
                        android:text="@string/booking_confirmed"
                        android:textColor="@color/green_success"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/success_message"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:textColor="@color/green_success"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Footer -->
        <include layout="@layout/footer_section" />
    </LinearLayout>
</ScrollView>

