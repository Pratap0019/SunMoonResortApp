<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header with Back Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/white"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            app:srcCompat="@drawable/ic_back"
            android:tint="@color/resort_gold_dark" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/admin"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/resort_gold"
            android:paddingStart="16dp" />
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center_horizontal">

            <!-- Decorative Space -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />

            <!-- Logo (if available) -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="32dp"
                android:contentDescription="@string/logo_description"
                android:scaleType="centerInside"
                android:tint="@color/resort_gold"
                app:srcCompat="@drawable/ic_launcher_foreground" />

            <!-- Title -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_login_title"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/resort_gold"
                android:textAlignment="center"
                android:layout_marginBottom="12dp" />

            <!-- Subtitle -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_login_subtitle"
                android:textSize="14sp"
                android:textColor="@color/text_brown"
                android:textAlignment="center"
                android:layout_marginBottom="48dp"
                android:lineSpacingExtra="4dp" />

            <!-- Password Input Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/password_input_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:boxBackgroundColor="@color/white"
                app:boxStrokeColor="@color/resort_gold"
                app:boxStrokeWidth="2dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:counterEnabled="false"
                app:errorTextColor="@color/red_error"
                app:hintTextColor="@color/resort_gold"
                app:textColorHint="@color/text_light">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/password_input"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="@string/password_hint"
                    android:inputType="textPassword"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_light"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:fontFamily="sans-serif" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Progress Indicator (hidden by default) -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_indicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:indicatorColor="@color/resort_gold" />

            <!-- Login Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/login_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/login"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:letterSpacing="0.05"
                app:backgroundTint="@color/resort_gold"
                app:cornerRadius="12dp"
                app:elevation="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Security Info -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 Your password is secure and encrypted"
                android:textSize="12sp"
                android:textColor="@color/text_light"
                android:textAlignment="center"
                android:layout_marginTop="32dp"
                android:drawablePadding="8dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>

