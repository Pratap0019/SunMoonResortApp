<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="300dp">

    <!-- Slide Image -->
    <ImageView
        android:id="@+id/carousel_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@string/carousel_slide" />

    <!-- Overlay with Caption -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/carousel_overlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="20dp">

            <TextView
                android:id="@+id/carousel_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/carousel_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/carousel_cta"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/book_now"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@color/resort_gold"
                android:textColor="@color/white"
                android:paddingStart="24dp"
                android:paddingEnd="24dp" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>

