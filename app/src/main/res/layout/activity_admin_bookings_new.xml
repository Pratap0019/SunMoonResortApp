<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_booking_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <FrameLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/header_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:id="@+id/logo_header"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/sunmoon_logo"
                    android:contentDescription="@string/logo_description"
                    android:scaleType="centerInside" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:src="@drawable/header_decoration"
                    android:contentDescription="@string/decoration_header"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingEnd="8dp">

                    <Button
                        android:id="@+id/new_booking_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/new_booking"
                        android:textSize="10sp"
                        android:background="@color/resort_gold"
                        android:textColor="@color/white"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <Button
                        android:id="@+id/logout_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/logout"
                        android:textSize="10sp"
                        android:background="@color/red_error"
                        android:textColor="@color/white"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Page Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bookings_information"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/resort_gold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_access_only"
                        android:textSize="12sp"
                        android:textColor="@color/gray_light"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Status Legend -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/confirmed"
                        android:textSize="10sp"
                        android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/status_confirmed"
                        app:chipStrokeColor="@color/status_confirmed" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/serving_guests"
                        android:textSize="10sp"
                        android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/status_staying"
                        app:chipStrokeColor="@color/status_staying" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/checked_out"
                        android:textSize="10sp"
                        android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/status_checked_out"
                        app:chipStrokeColor="@color/status_checked_out" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cancelled"
                        android:textSize="10sp"
                        app:chipBackgroundColor="@color/status_cancelled"
                        app:chipStrokeColor="@color/status_cancelled" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Empty State -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/empty_state_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_bookings_yet"
                        android:textSize="16sp"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bookings RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bookings_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="20dp"
                tools:listitem="@layout/item_admin_booking" />

            <!-- Full Room Inventory -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/text_dark"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/full_room_inventory"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- Room Inventory RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/room_inventory_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_room_inventory" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Footer -->
        <include layout="@layout/footer_section" />
    </LinearLayout>
</ScrollView>

