<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/gray_booking_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <FrameLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/header_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:gravity="center_vertical"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:paddingStart="0dp"
                android:paddingEnd="0dp">

                <ImageView
                    android:id="@+id/logo_header"
                    android:layout_width="170dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/logo_description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sunmoon_logo" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/decoration_header"
                    android:scaleType="centerCrop"
                    android:src="@drawable/header_decoration" />

                <ImageButton
                    android:id="@+id/back_button"
                    android:layout_width="50dp"
                    android:layout_height="40dp"
                    android:background="@color/white"
                    android:contentDescription="@string/back"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_back"
                    app:tint="@color/resort_gold_dark" />
            </LinearLayout>
        </FrameLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/new_booking_btn"
                    android:layout_width="68dp"
                    android:layout_height="28dp"
                    android:backgroundTint="@color/resort_gold_dark"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:text="@string/new_booking"
                    android:textColor="@color/white"
                    android:textSize="8sp" />

                <Button
                    android:id="@+id/logout_btn"
                    android:layout_width="68dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="@color/red_error"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:text="@string/logout"
                    android:textColor="@color/white"
                    android:textSize="8sp" />
            </LinearLayout>

            <!-- Page Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextSunMoonResortHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bookings_information"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/resort_gold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_access_only"
                        android:textColor="@color/black"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Status Legend -->

            <!-- SECTION 1: Ongoing Bookings -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ongoing_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Section Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@color/status_staying"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/TextSunMoonResortHeading"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/ongoing_bookings"
                            android:textColor="@color/text_dark"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/ongoing_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_dark"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Empty state for ongoing -->
                    <TextView
                        android:id="@+id/ongoing_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="24dp"
                        android:text="@string/no_ongoing_bookings"
                        android:textColor="@color/text_light"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- Ongoing RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/ongoing_bookings_list"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:nestedScrollingEnabled="true"
                        android:scrollbars="vertical"
                        tools:listitem="@layout/item_admin_booking" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 2: Completed / Cancelled Bookings -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/completed_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Section Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@color/gray_light"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/TextSunMoonResortHeading"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/completed_cancelled_bookings"
                            android:textColor="@color/text_dark"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/completed_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_dark"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Empty state for completed -->
                    <TextView
                        android:id="@+id/completed_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="24dp"
                        android:text="@string/no_completed_bookings"
                        android:textColor="@color/text_light"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- Completed RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/completed_bookings_list"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:nestedScrollingEnabled="true"
                        android:scrollbars="vertical"
                        tools:listitem="@layout/item_admin_booking" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Full Room Inventory -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/text_dark"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            style="@style/TextSunMoonResortHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/full_room_inventory"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- Column Headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:background="#EEEEEE">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.7"
                            android:text="Room"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:text="Type"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Status"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="Booked Dates"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:includeFontPadding="false" />
                    </LinearLayout>

                    <!-- Room Inventory RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/room_inventory_list"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:nestedScrollingEnabled="true"
                        android:scrollbars="vertical"
                        tools:listitem="@layout/item_room_inventory" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Footer -->
        <include layout="@layout/footer_section" />
    </LinearLayout>
</ScrollView>

