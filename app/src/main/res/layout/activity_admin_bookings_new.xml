<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/gray_booking_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <FrameLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/header_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:gravity="center_vertical"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:paddingStart="0dp"
                android:paddingEnd="0dp">

                <ImageView
                    android:id="@+id/logo_header"
                    android:layout_width="170dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/logo_description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sunmoon_logo" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/decoration_header"
                    android:scaleType="centerCrop"
                    android:src="@drawable/header_decoration" />

                <Button
                    android:id="@+id/back_button"
                    style="@style/Widget.SunMoonResort.HeaderNavButton"
                    android:text="@string/back"
                    android:textAllCaps="true" />
            </LinearLayout>
        </FrameLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/new_booking_btn"
                    android:layout_width="68dp"
                    android:layout_height="28dp"
                    android:backgroundTint="@color/resort_gold_dark"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:text="@string/new_booking"
                    android:textColor="@color/white"
                    android:textSize="8sp" />

                <Button
                    android:id="@+id/logout_btn"
                    android:layout_width="68dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="@color/red_error"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:text="@string/logout"
                    android:textColor="@color/white"
                    android:textSize="8sp" />
            </LinearLayout>

            <!-- Page Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextSunMoonResortHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bookings_information"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/resort_gold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_access_only"
                        android:textColor="@color/black"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Status Legend -->

            <!-- Empty State -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/empty_state_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="32dp">

                    <TextView
                        style="@style/TextSunMoonResortHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_bookings_yet"
                        android:textSize="16sp"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bookings RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bookings_list"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:nestedScrollingEnabled="true"
                android:scrollbars="vertical"
                android:layout_marginBottom="20dp"
                tools:listitem="@layout/item_admin_booking" />

            <!-- Full Room Inventory -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/text_dark"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            style="@style/TextSunMoonResortHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/full_room_inventory"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- Room Inventory RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/room_inventory_list"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:nestedScrollingEnabled="true"
                        android:scrollbars="vertical"
                        tools:listitem="@layout/item_room_inventory" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Footer -->
        <include layout="@layout/footer_section" />
    </LinearLayout>
</ScrollView>

